# Copy to .env.local (gitignored).
VITE_API_BASE_URL=https://api.upmovies.localhost
# VITE_PUBLIC_SITE_URL production value is https://backlotter.com.
# Must match the backend PUBLIC_BASE_URL; the sitemap proxy lists URLs sourced from the backend origin.
VITE_PUBLIC_SITE_URL=https://app.upmovies.localhost
VITE_TMDB_IMAGE_BASE=https://image.tmdb.org/t/p
# VITE_SENTRY_DSN=<your-upmovies-frontend-Sentry-DSN>
# Cloudflare Pages build: VITE_GIT_SHA=$CF_PAGES_COMMIT_SHA pnpm install --frozen-lockfile && pnpm build

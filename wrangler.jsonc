{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "upmovies-frontend",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./workers/app.ts",
  "observability": { "enabled": true },
  "vars": {
    "API_BASE_URL": "https://api.upmovies.localhost"
  }
}
